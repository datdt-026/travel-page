# ========================================
# Docker Environment Variables
# Copy this file to .env and update values
# ========================================

# PostgreSQL Database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=travel_cms

# PayloadCMS
PAYLOAD_SECRET=your-super-secret-key-minimum-32-characters-long

# CMS URLs
# For local development with Docker
PAYLOAD_PUBLIC_SERVER_URL=http://localhost:3001

# For production (replace with your domain)
# PAYLOAD_PUBLIC_SERVER_URL=https://cms.yourdomain.com

# Next.js Frontend URLs
# For local development with Docker
NEXT_PUBLIC_CMS_URL=http://localhost:3001
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# For production (replace with your domain)
# NEXT_PUBLIC_CMS_URL=https://cms.yourdomain.com
# NEXT_PUBLIC_SITE_URL=https://yourdomain.com
