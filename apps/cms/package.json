{
  "name": "@travel/cms",
  "version": "1.0.0",
  "private": true,
  "description": "PayloadCMS backend for travel site",
  "main": "dist/server.js",
  "scripts": {
    "# ===== MIGRATIONS (standalone, never in dev loop) =====": "",
    "migrate": "cross-env PAYLOAD_CONFIG_PATH=src/payload.config.ts payload migrate",
    "migrate:ci": "cross-env PAYLOAD_CONFIG_PATH=src/payload.config.ts CI=true payload migrate",
    "migrate:status": "cross-env PAYLOAD_CONFIG_PATH=src/payload.config.ts payload migrate:status",
    "migrate:create": "cross-env PAYLOAD_CONFIG_PATH=src/payload.config.ts payload migrate:create",
    "migrate:down": "cross-env PAYLOAD_CONFIG_PATH=src/payload.config.ts payload migrate:down",
    "migrate:reset": "cross-env PAYLOAD_CONFIG_PATH=src/payload.config.ts PAYLOAD_DROP_DATABASE=true payload migrate:reset",
    "# ===== DEVELOPMENT (CI=true prevents prompts) =====": "",
    "dev": "cross-env PAYLOAD_CONFIG_PATH=src/payload.config.ts CI=true nodemon",
    "dev:unsafe": "cross-env PAYLOAD_CONFIG_PATH=src/payload.config.ts nodemon",
    "# ===== BUILD =====": "",
    "build": "cross-env PAYLOAD_CONFIG_PATH=src/payload.config.ts DISABLE_ESLINT_PLUGIN=true payload build && tsc",
    "# ===== PRODUCTION (CI=true, no prompts allowed) =====": "",
    "start": "cross-env PAYLOAD_CONFIG_PATH=dist/payload.config.js NODE_ENV=production CI=true node dist/server.js",
    "# ===== UTILITIES =====": "",
    "generate:types": "cross-env PAYLOAD_CONFIG_PATH=src/payload.config.ts payload generate:types",
    "seed": "cross-env PAYLOAD_CONFIG_PATH=src/payload.config.ts CI=true ts-node --transpile-only src/seed/index.ts",
    "seed:editorial": "cross-env PAYLOAD_CONFIG_PATH=src/payload.config.ts CI=true ts-node --transpile-only src/seed/editorial-itineraries.ts",
    "lint": "eslint src --ext .ts,.tsx",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist build"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.965.0",
    "@aws-sdk/lib-storage": "^3.965.0",
    "@payloadcms/bundler-webpack": "^1.0.7",
    "@payloadcms/db-postgres": "^0.8.7",
    "@payloadcms/plugin-cloud-storage": "^1.0.0",
    "@payloadcms/richtext-slate": "^1.5.2",
    "cross-env": "^7.0.3",
    "dotenv": "^16.4.1",
    "drizzle-orm": "^0.29.3",
    "express": "^4.18.2",
    "payload": "^2.25.0"
  },
  "devDependencies": {
    "@swc/core": "^1.15.43",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "eslint": "^8.56.0",
    "nodemon": "^3.0.3",
    "rimraf": "^5.0.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  },
  "overrides": {
    "drizzle-kit": "0.20.14"
  },
  "nodemonConfig": {
    "ext": "ts",
    "exec": "cross-env CI=true ts-node --transpile-only src/server.ts",
    "watch": [
      "src"
    ],
    "ignore": [
      "src/migrations/*"
    ]
  }
}
